# IndusMind frontend (Vite + React). Copy to `.env.local` to run:
#     cp .env.example .env.local
#
# Only VITE_-prefixed vars reach the browser bundle — anything else is ignored.
# Never put an AI/provider API key here: this file is compiled into client-side
# JS and would be readable by anyone who loads the page. All LLM calls go through
# the backend, which holds the keys server-side (see BACKEND/.env.example).

# live = talk to the real backend. mock = use the built-in in-memory fixtures
# (no backend needed; useful for UI-only work).
VITE_API_MODE=live

# Base URL of the backend API. The backend's CORS_ORIGINS must allow this dev
# server's origin (http://localhost:3000 by default).
VITE_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket endpoint for realtime notifications + ingestion progress.
VITE_WS_URL=ws://localhost:8000/ws
