# ── IndusMind backend · canonical environment (docs/02 §49) ──────────────────
# Copy to .env for local dev. .env is gitignored; never commit real secrets.
#
# These defaults target the DOCUMENTED LOCAL FLOW: datastores in docker-compose,
# API + worker on the host venv (see the root README). Hence localhost + the
# published host ports, which docker-compose.override.yml remaps to 5433/6380 to
# dodge a native Postgres/Redis already holding 5432/6379.
#
# The compose `api`/`worker`/`beat` services do NOT read this file — they get
# their datastore URLs from the `x-app-env` anchor in docker-compose.yml, which
# uses the in-network hostnames (postgres:5432, redis:6379). So these values only
# ever describe the host case; don't "fix" them to container hostnames.

# Application
APP_ENV=local                       # local | staging | prod
SECRET_KEY=change-me-dev-secret
LOG_LEVEL=INFO

# JWT (RS256). For local dev leave the *_KEY vars empty to auto-generate an
# ephemeral dev keypair at startup. In prod inject PEM strings from secrets mgr.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL=900                 # 15 min
REFRESH_TOKEN_TTL=604800             # 7 days

# PostgreSQL 16 (+pgvector). Async driver. Host port 5433 (compose override).
DATABASE_URL=postgresql+asyncpg://indusmind:indusmind@localhost:5433/indusmind

# Redis 7 (cache / Celery broker / pubsub / rate-limit). Host port 6380 (override).
REDIS_URL=redis://localhost:6380/0

# Neo4j 5
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=indusmind-neo4j

# Object storage (MinIO local / S3 prod) — boto3-compatible
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=indusmind
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
AWS_REGION=us-east-1

# LLM / embeddings / OCR provider adapters
# Leave every key blank to run fully offline: each provider falls back to a
# deterministic mock, so ingestion/search/CRUD work without any AI account.
LLM_PROVIDER=anthropic               # anthropic | openai | gemini | grok | ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1    # xAI is OpenAI chat-completions compatible
OLLAMA_URL=http://localhost:11434
EMBEDDING_PROVIDER=local             # local | openai
EMBEDDING_MODEL=bge-large-en-v1.5
OCR_PROVIDER=paddle                  # paddle | textract

# HTTP / CORS
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true

# OAuth (optional)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Mail delivery adapter (mirrors the LLM/OCR adapters)
MAIL_PROVIDER=smtp                  # smtp (mailhog local / real SMTP prod) | ses (prod)
# SMTP (mailhog local — web UI at http://localhost:8025 catches every send)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@indusmind.local

# Observability
SENTRY_DSN=

# Feature flags default JSON (global fallback before DB flags load)
FEATURE_DEFAULTS_JSON={}
