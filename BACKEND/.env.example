# ── IndusMind backend · canonical environment (docs/02 §49) ──────────────────
# Copy to .env for local dev. .env is gitignored; never commit real secrets.

# Application
APP_ENV=local                       # local | staging | prod
SECRET_KEY=change-me-dev-secret
LOG_LEVEL=INFO

# JWT (RS256). For local dev leave the *_KEY vars empty to auto-generate an
# ephemeral dev keypair at startup. In prod inject PEM strings from secrets mgr.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL=900                 # 15 min
REFRESH_TOKEN_TTL=604800             # 7 days

# PostgreSQL 16 (+pgvector). Async driver.
DATABASE_URL=postgresql+asyncpg://indusmind:indusmind@postgres:5432/indusmind

# Redis 7 (cache / Celery broker / pubsub / rate-limit)
REDIS_URL=redis://redis:6379/0

# Neo4j 5
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=indusmind-neo4j

# Object storage (MinIO local / S3 prod) — boto3-compatible
S3_ENDPOINT=http://minio:9000
S3_BUCKET=indusmind
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
AWS_REGION=us-east-1

# LLM / embeddings / OCR provider adapters
LLM_PROVIDER=anthropic               # anthropic | openai | ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434
EMBEDDING_PROVIDER=local             # local | openai
EMBEDDING_MODEL=bge-large-en-v1.5
OCR_PROVIDER=paddle                  # paddle | textract

# HTTP / CORS
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true

# OAuth (optional)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# SMTP (mailhog local)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@indusmind.local

# Observability
SENTRY_DSN=

# Feature flags default JSON (global fallback before DB flags load)
FEATURE_DEFAULTS_JSON={}
